{
	"name": "@guapocado/sdk",
	"version": "0.0.7",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./testing": {
			"import": "./dist/testing.js",
			"types": "./dist/testing.d.ts"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup src/index.ts src/testing.ts --format esm --dts",
		"test": "vitest run",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@guapocado/shared": "workspace:*"
	},
	"peerDependencies": {
		"vitest": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"vitest": {
			"optional": true
		}
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.7",
		"fast-check": "^3.23.2"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/guapocado/guapocado.git",
		"directory": "packages/sdk"
	}
}
