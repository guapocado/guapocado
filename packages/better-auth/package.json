{
	"name": "@guapocado/better-auth",
	"version": "0.0.3",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsup src/index.ts src/client.ts --format esm --dts",
		"test": "vitest run",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@guapocado/sdk": "workspace:*",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"better-auth": "^1.6.11",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"better-auth": "^1.6.11"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/guapocado/guapocado.git",
		"directory": "packages/better-auth"
	}
}
