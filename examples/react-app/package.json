{
	"name": "guapocado-example-react",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 0.0.0.0",
		"guap:init": "guap init --format json",
		"guap:login": "guap login",
		"guap:plan:test": "guap plan --test",
		"guap:push:test": "guap push --test",
		"dx:check": "pnpm typecheck && guap init --format json",
		"typecheck": "tsc --noEmit",
		"build": "tsc --noEmit && vite build"
	},
	"dependencies": {
		"@guapocado/cli": "workspace:*",
		"@guapocado/react": "workspace:*",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.7.0",
		"vite": "^7.2.0"
	}
}
